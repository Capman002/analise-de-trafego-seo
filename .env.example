# ─── Backend ─────────────────────────────────────────────
PORT=8080
DB_PATH=./data/analise-trafego.db
CORS_ORIGIN=http://localhost:5173

# ─── Basic Auth (Acesso ao Painel e API) ─────────────────
API_USER=admin
API_PASS=admin

# ─── Google Sheets (público — sem auth) ──────────────────
SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# ─── Google API (Service Account JSON para GSC/GA4) ───────────
# Cole o conteúdo do arquivo JSON da Conta de Serviço em uma única linha.
GOOGLE_CREDENTIALS_JSON='{"type": "service_account", "project_id": "...", "private_key": "...", ...}'

# ─── Bing Webmaster Tools ────────────────────────────────
BING_API_KEY=your_bing_api_key_here

# ─── Sync ────────────────────────────────────────────────
SYNC_ON_STARTUP=true
