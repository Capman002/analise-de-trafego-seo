# ─── Backend ─────────────────────────────────────────────
PORT=8080
DB_PATH=./data/analise-trafego.db
CORS_ORIGIN=http://localhost:5173

# ─── Basic Auth (Acesso ao Painel e API) ─────────────────
API_USER=admin
API_PASS=admin

# ─── Google Sheets (público — sem auth) ──────────────────
SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# ─── Google OAuth2 (Credenciais de Autenticação GSC/GA4) ───────────
# 1. Crie as Credenciais Web OAuth no Google Cloud.
# 2. Rode o utilitário localmente: cd backend && go run cmd/auth-generator/main.go
# 3. Cole abaixo os dois JSONs gerados.
GOOGLE_CREDENTIALS_JSON='{"web":{"client_id":"...","client_secret":"..."}}'
GOOGLE_TOKEN_JSON='{"access_token":"...","refresh_token":"...","token_type":"Bearer"}'

# ─── Bing Webmaster Tools ────────────────────────────────
BING_API_KEY=your_bing_api_key_here

# ─── Sync ────────────────────────────────────────────────
SYNC_ON_STARTUP=true
